# ============================================================================
# AWS Credentials
# ============================================================================
# SECURITY WARNING: Never commit actual credentials to version control!
# These are optional - credentials can be provided via the UI
# For production, use IAM roles or AWS SSO instead of access keys

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# ============================================================================
# Backend Configuration
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ============================================================================
# Frontend Configuration
# ============================================================================
# For development
NEXT_PUBLIC_API_URL=http://localhost:8000

# For production, update to your actual backend URL
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ============================================================================
# Amazon Bedrock Configuration
# ============================================================================
# Primary model for AI operations
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=us-east-1

# Fallback models (comma-separated)
BEDROCK_FALLBACK_MODELS=anthropic.claude-3-5-sonnet-20240620-v1:0,anthropic.claude-3-sonnet-20240229-v1:0

# ============================================================================
# AWS Marketplace Configuration
# ============================================================================
MARKETPLACE_SELLER_ACCOUNT_ID=
MARKETPLACE_CATALOG_REGION=us-east-1

# ============================================================================
# Bedrock AgentCore (Future)
# ============================================================================
# AGENTCORE_RUNTIME_ARN=
# AGENTCORE_MEMORY_ID=
# AGENTCORE_GATEWAY_ID=

# ============================================================================
# Application Settings
# ============================================================================
LOG_LEVEL=INFO
DEBUG=false

# Session configuration
SESSION_TIMEOUT=3600
MAX_SESSIONS=100

# ============================================================================
# Security Settings
# ============================================================================
# CORS Settings - Update for production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# For production, specify your actual domains:
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate limiting (requests per minute)
RATE_LIMIT=60

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_CHATBOT=true
ENABLE_SAAS_DEPLOYMENT=true
ENABLE_ANALYTICS=false

# ============================================================================
# Monitoring and Observability
# ============================================================================
# CLOUDWATCH_LOG_GROUP=/aws/marketplace-listing-agent
# XRAY_ENABLED=false

# ============================================================================
# Development Settings
# ============================================================================
# Set to true only in development
HOT_RELOAD=true
VERBOSE_LOGGING=false
