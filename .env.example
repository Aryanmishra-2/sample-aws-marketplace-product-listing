# AWS Credentials (Optional - can be provided via UI)
# Leave empty to use UI-based credential input
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend Configuration (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Bedrock Configuration
# Primary model to use for AI operations
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=us-east-1

# AWS Marketplace (Optional)
MARKETPLACE_SELLER_ACCOUNT_ID=

# Knowledge Base (Optional - for future use)
KNOWLEDGE_BASE_ID=

# Application Settings
LOG_LEVEL=INFO
DEBUG=false

# CORS Settings (for production, specify your domain)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
